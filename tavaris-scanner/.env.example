# Bu dosyalar genelde repo kökünde (qr-scanner/.env.local) — vite.config envDir ile oradan okunur.
#
# Google Apps Script Web App URL (Deploy → Web app → URL)
# Örnek: https://script.google.com/macros/s/XXXX/exec
VITE_APPS_SCRIPT_URL=

# Üst bardaki isim: sheet’te APP_BRAND_NAME yoksa / eskiyse buradan zorla (build öncesi ayarla)
# VITE_APP_BRAND_NAME=Etkinlik Adınız
